rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: games
    // Document ID: uuid
    // Fields:
    //   - id: string (required) - unique identifier
    //   - name: string (required, size < 100) - name of the game
    //   - url: string (required, matches url pattern) - source url for the game
    //   - thumbnail: string (optional, size < 500) - image url
    //   - description: string (optional, size < 500) - short description
    //   - createdAt: timestamp (optional)
    //
    // Collection: users
    // Document ID: userId from auth
    // Fields:
    //   - uid: string (required)
    //   - email: string (required)
    //   - role: string (required, ['admin', 'user'])
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "farabi.reyhan@gmail.com" && request.auth.token.email_verified == true));
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isValidGame(data) {
      return data.id is string &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.url is string && (data.url.matches("^https://.*") || data.url.matches("^http://.*")) &&
             (!('thumbnail' in data) || (data.thumbnail is string && data.thumbnail.size() < 500)) &&
             (!('description' in data) || (data.description is string && data.description.size() < 500));
    }

    function isValidUser(data) {
      return data.uid is string &&
             data.email is string &&
             data.role in ['admin', 'user'];
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isAuthenticated() && isValidUser(request.resource.data) && 
                    ((isOwner(userId) && request.resource.data.role == 'user') || isAdmin());
      allow update: if isAuthenticated() && isValidUser(request.resource.data) && 
                    ((isOwner(userId) && request.resource.data.role == resource.data.role) || isAdmin());
    }

    match /games/{gameId} {
      // Publicly readable for everyone to enjoy the games
      allow read: if true;
      
      // Only authorized admins can modify the game catalog
      allow create: if isAdmin() && isValidGame(request.resource.data);
      allow update: if isAdmin() && isValidGame(request.resource.data);
      allow delete: if isAdmin();
    }
  }
}
